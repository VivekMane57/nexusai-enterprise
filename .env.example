# =========================================================
# Application
# =========================================================
APP_NAME=NexusAI Enterprise
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1

# =========================================================
# CORS
# JSON array format is required
# =========================================================
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# =========================================================
# PostgreSQL
# Local backend -> localhost
# Docker Compose overrides this value for the API container
# =========================================================
POSTGRES_USER=nexusai
POSTGRES_PASSWORD=nexusai_dev_password
POSTGRES_DB=nexusai
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://nexusai:nexusai_dev_password@127.0.0.1:5432/nexusai

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# =========================================================
# Redis
# =========================================================
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT=5

# =========================================================
# Qdrant
# =========================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=5

# =========================================================
# Authentication
# Replace before production
# =========================================================
JWT_SECRET_KEY=replace-this-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================================
# Azure OpenAI
# Values can remain blank during Sprint 1
# =========================================================
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# =========================================================
# Local AI models
# =========================================================
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2